{
	"i18n": true,
	"type": "panel",
	"items": {
		"_info": {
			"type": "header",
			"text": "info_header",
			"size": 3
		},
		"forecastHours": {
			"type": "select",
			"label": "forecastHours",
			"sm": 12,
			"md": 6,
			"lg": 4,
			"options": [
				{"label": "3", "value": 3},
				{"label": "6", "value": 6},
				{"label": "12", "value": 12},
				{"label": "24", "value": 24},
				{"label": "48", "value": 48}
			],
			"newLine": true
		},
		"forecastDays": {
			"type": "select",
			"label": "forecastDays",
			"sm": 12,
			"md": 6,
			"lg": 4,
			"default": 7,
			"options": [
				{"label": "3", "value": 3},
				{"label": "5", "value": 5},
				{"label": "7", "value": 7},
				{"label": "14", "value": 14}
			]
		},
		"updateInterval": {
			"type": "select",
			"label": "updateInterval",
			"sm": 12,
			"md": 6,
			"lg": 4,
			"default": 15,
			"options": [
				{ "value": 15, "label": "interval_15_min" },
				{ "value": 30, "label": "interval_30_min" },
				{ "value": 60, "label": "interval_60_min" }
			],
			"help": "updateInterval_help"
		},
		"_locationsHeader": {
			"type": "header",
			"text": "locations_header",
			"size": 3,
			"newLine": true
		},
		"locations": {
			"type": "table",
			"newLine": true,
			"label": "locations",
			"items": [
				{
					"type": "text",
					"title": "name",
					"attr": "name",
					"width": "20%",
					"filter": false,
					"sort": true,
					"validator": "data.name && data.name.length > 0"
				},
				{
					"type": "text",
					"title": "latitude",
					"attr": "latitude",
					"width": "13%",
					"filter": false,
					"sort": false,
					"validator": "data.latitude !== undefined && data.latitude >= -90 && data.latitude <= 90",
					"help": {
						"en": "Leave empty to use system latitude",
						"de": "Leer lassen, um System-Breitengrad zu verwenden",
						"fr": "Laissez vide pour utiliser la latitude du système",
						"es": "Dejar vacío para usar la latitud del sistema",
						"it": "Lascia vuoto per utilizzare la latitudine del sistema",
						"pt": "Deixe vazio para usar a latitude do sistema",
						"nl": "Leeg laten om systeem breedtegraad te gebruiken",
						"pl": "Pozostaw puste, aby użyć szerokości geograficznej systemu",
						"ru": "Оставьте пустым, чтобы использовать широту системы",
						"uk": "Залиште порожнім, щоб використовувати широту системы",
						"zh-cn": "留空以使用系统纬度"
					}
				},
                { 
					"type": "text",
					"title": "longitude",
					"attr": "longitude",
					"width": "13%",
					"filter": false,
					"sort": false,
					"validator": "data.longitude !== undefined && data.longitude >= -180 && data.longitude <= 180",
					"help": {
						"en": "Leave empty to use system longitude",
						"de": "Leer lassen, um System-Längengrad zu verwenden",
						"fr": "Laissez vide pour utiliser la longitude du système",
						"es": "Dejar vacío para usar la longitud del sistema",
						"it": "Lascia vuoto per utilizzare la longitudine del sistema",
						"pt": "Deixe vazio para usar a longitude do sistema",
						"nl": "Leeg laten om systeem lengtegraad te gebruiken",
						"pl": "Pozostaw puste, aby użyć długości geograficznej systemu",
						"ru": "Оставьте пустым, чтобы использовать долготу системы",
						"uk": "Залиште порожнім, щоб використовувати довготу системи",
						"zh-cn": "留空以使用系统经度"
					}
				},
				{
					"type": "number",
					"title": "tilt",
					"attr": "tilt",
					"width": "13%",
					"filter": false,
					"sort": false,
					"min": 0,
					"max": 90,
					"validator": "data.tilt !== undefined && data.tilt >= 0 && data.tilt <= 90"
				},
				{
					"type": "number",
					"title": "azimuth",
					"attr": "azimuth",
					"width": "13%",
					"filter": false,
					"sort": false,
					"min": -180,
					"max": 180,
					"validator": "data.azimuth !== undefined && data.azimuth >= -180 && data.azimuth <= 180"
				},
				{
					"type": "number",
					"title": "kwp",
					"attr": "kwp",
					"width": "13%",
					"filter": false,
					"sort": false,
					"min": 0,
					"validator": "data.kwp !== undefined && data.kwp >= 0"
				},
				{
					"type": "select",
					"title": "timezone",
					"attr": "timezone",
					"width": "18%",
					"filter": false,
					"sort": false,
					"validator": "data.timezone && data.timezone.length > 0",
					"options":[
							{ "value": "auto", "label": "autom" },
							{ "value": "GMT", "label": "GMT / UTC" },
							{ "value": "Europe/Berlin", "label": "Europa/Berlin" },
							{ "value": "Europe/London", "label": "Europe/London" },
							{ "value": "Europe/Moscow", "label": "Europe/Moscow" },
							{ "value": "America/New_York", "label": "America/New York" },
							{ "value": "America/Chicago", "label": "America/Chicago" },
							{ "value": "America/Denver", "label": "America/Denver" },
							{ "value": "America/Los_Angeles", "label": "America/Los Angeles" },
							{ "value": "America/Sao_Paulo", "label": "America/Sao Paulo" },
							{ "value": "America/Anchorage", "label": "America/Anchorage" },
							{ "value": "Asia/Tokyo", "label": "Asia/Tokyo" },
							{ "value": "Asia/Bangkok", "label": "Asia/Bangkok" },
							{ "value": "Asia/Singapore", "label": "Asia/Singapore" },
							{ "value": "Australia/Sydney", "label": "Australia/Sydney" },
							{ "value": "Africa/Cairo", "label": "Afrika/Cairo" },
							{ "value": "Pacific/Auckland", "label": "Pacific/Auckland" }
						],
						"default": "auto"
				},
				{
					"type": "custom",
					"label": "actions",
					"i18n": true
				}
			]
		},
		"_locationHelp": {
			"type": "staticText",
			"text": "location_help",
			"newLine": true,
			"style": {
				"fontSize": "smaller",
				"fontStyle": "italic"
			}
		},
		"locationsTotal": {
			"type": "checkbox",
			"label": "locationsTotal_label",
			"default": false,
			"help": "locationsTotal_help",
			"hidden": "!data.locations || data.locations.length < 2",
			"xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3
        }
	}
}